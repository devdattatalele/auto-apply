{
  "name": "job-auto-apply",
  "version": "1.1.0",
  "description": "Autonomous job application engine — Playwright-based form filler with self-learning, OTP handling, and multi-ATS support",
  "type": "module",
  "bin": {
    "auto-apply": "./cli.mjs"
  },
  "files": [
    "cli.mjs",
    "lib/",
    "config/profile.example.yml",
    "config/resumes.example.yml",
    "targets.example.txt",
    ".env.example",
    ".claude/",
    "CLAUDE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "node cli.mjs setup",
    "scan": "node cli.mjs scan",
    "fill": "node cli.mjs fill",
    "apply": "node cli.mjs apply",
    "batch": "node cli.mjs batch",
    "queue": "node cli.mjs queue",
    "status": "node cli.mjs status",
    "postinstall": "npx playwright install chromium 2>/dev/null || echo 'Run: npx playwright install chromium'"
  },
  "keywords": [
    "job-application",
    "automation",
    "playwright",
    "form-filler",
    "ats",
    "greenhouse",
    "ashby",
    "lever",
    "workday",
    "claude-code",
    "self-learning",
    "job-search",
    "career",
    "apply",
    "npx"
  ],
  "author": "Devdatta Talele",
  "license": "MIT",
  "homepage": "https://github.com/devdattatalele/auto-apply#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devdattatalele/auto-apply.git"
  },
  "bugs": {
    "url": "https://github.com/devdattatalele/auto-apply/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "imapflow": "^1.3.1",
    "js-yaml": "^4.1.1",
    "playwright": "^1.58.1"
  }
}
